# ============================================================
# Blue Zone — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ---- NextAuth -----------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ---- Google OAuth -------------------------------------------
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email Magic Link (Resend SDK) --------------------------
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=onboarding@resend.dev

# ---- Supabase -----------------------------------------------
# Find at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Anthropic Claude (Protocol Engine) ---------------------
# Create at: https://console.anthropic.com/settings/keys
# Used for: lib/ai/generateProtocol.ts — longevity analysis
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional: override the default model
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- WHOOP OAuth -------------------------------------------
# Register at: https://developer.whoop.com
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Redirect URI registered in WHOOP developer console:
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback

# ---- Google Places API ------------------------------------
# Enable "Places API" at: https://console.cloud.google.com/apis/library
GOOGLE_PLACES_API_KEY=

# ---- OCR: AWS Textract ------------------------------------
# Create an IAM user with AmazonTextractFullAccess
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ---- Amazon Product Advertising API v5 --------------------
# Apply at: https://affiliate-program.amazon.com/assoc_credentials/home
# Requires an existing Associates account with qualifying sales
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=your-tag-20
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1

# ---- iHerb Affiliate --------------------------------------
# Apply at: https://www.iherb.com/info/affiliate-program
IHERB_AFFILIATE_CODE=your-iherb-code

# ---- Stripe (Billing) -------------------------------------
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret
# Price IDs from your Stripe dashboard
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_CLINIC=price_your_clinic_price_id

# ---- OpenAI (legacy, kept for compatibility) ---------------
OPENAI_API_KEY=sk-your-key-here

# ---- Sentry (optional error tracking) ----------------------
NEXT_PUBLIC_SENTRY_DSN=
